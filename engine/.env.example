# ---------- Core ----------
OPENAI_API_KEY=
OPENAI_API_KEYS=
PEXELS_API_KEY=
PIXABAY_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_API_KEYS=
ELEVENLABS_VOICE_ID=

# ---------- Providers ----------
VOICE_PROVIDER_ORDER=openai,elevenlabs,kokoro,piper
TRANSCRIBE_PROVIDER_ORDER=openai,faster_whisper
FOOTAGE_PROVIDER_ORDER=pexels,pixabay
IMAGE_PROVIDER_ORDER=pexels,pixabay
RESEARCH_PROVIDER_ORDER=wikipedia,youtube_transcript,trafilatura,scrapling

# ---------- Models ----------
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TRANSCRIBE_MODEL=whisper-1
VOICE=alloy

# ---------- Runtime ----------
OUTPUT_ROOT=./output
STATE_ROOT=./state
DB_PATH=./state/jobs.sqlite3
CACHE_ROOT=./state/cache
PROFILES_ROOT=./profiles
MAX_WORKERS=3
MAX_RETRIES=4
RETRY_BASE_SECONDS=4
UPLOAD_TO_YOUTUBE=false
UPLOAD_THUMBNAIL=false
UPLOAD_CAPTIONS=false
USE_AI_THUMBNAIL=false
GENERATE_IDEAS=true
DISCLOSE_SYNTHETIC_MEDIA=false
DEFAULT_CATEGORY_ID=27
DEFAULT_PRIVACY_STATUS=private
PUBLISH_INTERVAL_MINUTES=90
SCHEDULE_START_AT=
DAILY_UPLOAD_SOFT_LIMIT=90
NOTIFY_SUBSCRIBERS=false

# ---------- Render ----------
VIDEO_FORMAT=shorts
FRAME_WIDTH=1080
FRAME_HEIGHT=1920
FPS=30
MIN_CLIPS=4
MAX_CLIPS=8
SUBTITLE_STYLE=bottom-box

# ---------- Moderation / Dedupe ----------
USE_OPENAI_MODERATION=true
DUPLICATE_THRESHOLD=0.82
BLOCKED_WORDS=

# ---------- Optional Local TTS ----------
KOKORO_LANG_CODE=a
KOKORO_VOICE=af_heart
PIPER_BIN=piper
PIPER_MODEL=
PIPER_CONFIG=

# ---------- Optional Local Transcription ----------
FASTER_WHISPER_MODEL=small


# ---- Web UI / assistant ----
ENABLE_BACKGROUND_SCANNER=true
TREND_SCAN_MINUTES=60
DEFAULT_TREND_GEO=VN
NEWSAPI_KEY=
SERPAPI_KEY=
GOOGLE_TRENDS_RSS_URL=
